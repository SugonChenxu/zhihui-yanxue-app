<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 夜间模式主题 -->
    <style name="Theme.ZhiHuiYanXue" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorPrimaryDark">@color/primary_red_dark</item>
        <item name="colorAccent">@color/accent_gold</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/primary_red_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- 背景（夜间模式会自动使用 values-night/colors.xml 中的值） -->
        <item name="android:windowBackground">@color/background</item>

        <!-- 文字颜色（夜间模式会自动使用 values-night/colors.xml 中的值） -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
