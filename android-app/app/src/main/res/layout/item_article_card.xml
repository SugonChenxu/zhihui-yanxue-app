<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:layout_marginEnd="10dp">

    <!-- 文章配图区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp">

        <!-- 渐变背景占位图 -->
        <View
            android:id="@+id/view_article_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_article_1" />

        <!-- 标签 -->
        <TextView
            android:id="@+id/txt_article_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tag_red"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="地标"
            android:textColor="@color/white"
            android:textSize="10sp" />

        <!-- 阅读量 -->
        <TextView
            android:id="@+id/txt_article_reads"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="6dp"
            android:background="#80000000"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="3.2k阅读"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </FrameLayout>

    <!-- 文字信息区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/txt_article_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文章标题"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txt_article_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="文章摘要内容"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txt_article_author"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="作者"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txt_article_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-04-15"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
