<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="28dp"
    android:gravity="center_horizontal">

    <!-- 签到成功标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="党史学习打卡成功"
        android:textColor="#C41E24"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- 积分奖励 -->
    <TextView
        android:id="@+id/txt_dialog_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+10"
        android:textColor="#C41E24"
        android:textSize="42sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="获得学习积分"
        android:textColor="#FF757575"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

    <!-- 连续签到天数 -->
    <TextView
        android:id="@+id/txt_dialog_continuous"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已连续签到7天"
        android:textColor="#D4AF37"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 阶段奖励提示 -->
    <TextView
        android:id="@+id/txt_dialog_reward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="阶段奖励 +20 积分"
        android:textColor="#D4AF37"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <!-- 提示文案 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="坚持常态化党史学习，传承红色基因"
        android:textColor="#FF9E9E9E"
        android:textSize="11sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp" />

    <!-- 确认按钮 -->
    <Button
        android:id="@+id/txt_dialog_confirm"
        android:layout_width="180dp"
        android:layout_height="44dp"
        android:text="继续学习"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:background="@drawable/bg_btn_primary" />

</LinearLayout>
